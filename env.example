# LLM API Keys (at least one required)
OPENAI_API_KEY=your-api-key
ANTHROPIC_API_KEY=your-api-key
GOOGLE_API_KEY=your-api-key
XAI_API_KEY=your-api-key
OPENROUTER_API_KEY=your-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# NZXplorer API (required)
NZXPLORER_API_KEY=your-nzxplorer-api-key
NZXPLORER_API_URL=https://nzxplorer.co.nz

# Web Search API Keys (Exa → Perplexity → Tavily)
EXASEARCH_API_KEY=your-api-key
PERPLEXITY_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key

# LangSmith Tracing (optional)
LANGSMITH_API_KEY=your-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=nzxplorer-agent
LANGSMITH_TRACING=true
